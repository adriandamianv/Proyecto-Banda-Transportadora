const express = require('express');
const app = express();

// Para poder leer los datos que envía el ESP32
app.use(express.urlencoded({ extended: true }));

app.post('/save_data', (req, res) => {
    const { uid, material, weight_kg } = req.body;
    
    console.log("--- NUEVO DATO RECIBIDO ---");
    console.log(`Usuario (UID): ${uid}`);
    console.log(`Material: ${material}`);
    console.log(`Peso: ${weight_kg} kg`);
    
    // Aquí el servidor responde al ESP32
    res.status(200).send("Dato guardado correctamente");
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
    console.log(`Servidor activo en puerto ${PORT}`);
});
